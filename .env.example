# Copy this file to .env for local-only configuration.
# This project is public market data only. Do not add API keys, private keys,
# wallet secrets, session keys, order credentials, or trading credentials here.

PERPDEX_DB_PATH=data/perpdex_phase1.sqlite

# markets.json decides which exchanges and markets are enabled.
# .env decides how this machine runs collection.
PERPDEX_COLLECTION_INTERVAL=30
PERPDEX_ORDERBOOK_DEPTH=100
PERPDEX_MAX_NOTIONAL_DEPTH=1000000
PERPDEX_ORDERBOOK_GRANULARITY=0.1
PERPDEX_PUBLIC_API_TIMEOUT=20
PERPDEX_PUBLIC_API_RETRIES=3
PERPDEX_COLLECTOR_LOG_PATH=data/logs/collector.log
